# MongoDB connection string (required for community hub, auth, and persistence)
# Get a free cluster at https://mongodb.com/atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/capstone?retryWrites=true&w=majority

# Pusher credentials (required for real-time messaging in community hub)
# Create a free app at https://pusher.com
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
PUSHER_APP_ID=your_pusher_app_id
PUSHER_SECRET=your_pusher_secret
NEXT_PUBLIC_PUSHER_CLUSTER=us2

# JWT secret for authentication tokens
JWT_SECRET=change-this-to-a-random-secret-in-production

# Groq API keys for AI features (comma-separated for rotation)
GROQ_API_KEYS=your_groq_api_key_here
